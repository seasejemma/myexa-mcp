{
  "$schema": "https://deno.land/x/deno/cli/schemas/config-file.v1.json",
  "compilerOptions": {
    "strict": true,
    "lib": ["deno.window", "deno.unstable", "dom", "dom.iterable"]
  },
  "nodeModulesDir": "auto",
  "deploy": {
    "runtime": {
      "type": "dynamic",
      "entrypoint": "./src/main_deno.ts"
    },
    "org": "seasejemma",
    "app": "myexa-mcp-public"
  },
  "imports": {
    "@modelcontextprotocol/sdk/server/mcp.js": "npm:@modelcontextprotocol/sdk@1.29.0/server/mcp.js",
    "@modelcontextprotocol/sdk/server/webStandardStreamableHttp.js": "npm:@modelcontextprotocol/sdk@1.29.0/server/webStandardStreamableHttp.js",
    "exa-js": "npm:exa-js@2.16.0",
    "std/assert": "jsr:@std/assert@1.0.15",
    "zod": "npm:zod@3.25.76"
  },
  "tasks": {
    "dev": "deno run --allow-env --allow-net --allow-read --watch src/main_deno.ts",
    "start": "deno run --allow-env --allow-net --allow-read src/main_deno.ts",
    "check": "deno check src/main_deno.ts scripts/check-env.ts scripts/smoke.ts",
    "check-env": "deno run --allow-env scripts/check-env.ts",
    "test": "deno test --allow-env --allow-net --allow-read tests",
    "ci": "deno fmt --check && deno lint && deno task check && deno task test",
    "smoke": "deno run --allow-env --allow-net scripts/smoke.ts"
  }
}
